# ====================================================================
# ❤️ 心率监测中转站 (Heart Rate Relay) Caddy 配置文件
# ====================================================================

# 选项一：如果您有公网域名 (推荐，Caddy 会自动申请并续期免费 SSL 证书，启用 wss:// 加密)
# 请将 below_domain.com 替换为您实际拥有的域名，例如 hr.example.com
your-domain.com {
    # 反向代理到 server 服务的 8765 端口 (Caddy 自动支持 WebSocket 透明转发)
    reverse_proxy server:8765
}

# 选项二：如果您仅使用公网 IP 进行临时测试（默认开启，使用 HTTP/ws，无加密）
# 注意：若要启用选项一的域名，请将下方这部分注释掉或删除
:80 {
    reverse_proxy server:8765
}
