<Window x:Class="HeartRateOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="心率悬浮窗"
        Width="140" Height="60"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Left="20" Top="20"
        Icon="app_icon.ico"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <Storyboard x:Key="HeartBeat">
            <DoubleAnimation Storyboard.TargetName="HeartScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="1.25" Duration="0:0:0.1" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="HeartScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="1.25" Duration="0:0:0.1" AutoReverse="True"/>
        </Storyboard>
    </Window.Resources>
    
    <Grid>
        <Border x:Name="MainBorder"
                Background="#D80A0A19"
                BorderBrush="#25FFFFFF"
                BorderThickness="1.2"
                CornerRadius="26"
                Margin="4"
                Padding="10,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="6" Opacity="0.4" ShadowDepth="1"/>
            </Border.Effect>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Beating Heart Icon -->
                <Viewbox Width="26" Height="26" Grid.Column="0" VerticalAlignment="Center" Margin="2,0,6,0">
                    <Path Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09 C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5 c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                          Fill="#FF2D55">
                        <Path.RenderTransform>
                            <ScaleTransform x:Name="HeartScale" CenterX="12" CenterY="12"/>
                        </Path.RenderTransform>
                    </Path>
                </Viewbox>
                
                <!-- Heart Rate Text -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtHR" Text="--" FontSize="24" FontWeight="Black" FontFamily="Segoe UI, Inter" Foreground="#FF2D55" VerticalAlignment="Bottom"/>
                    <TextBlock x:Name="TxtUnit" Text=" BPM" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI, Inter" Foreground="#8888AA" VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
