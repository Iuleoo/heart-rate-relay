<Window x:Class="HeartRateOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="心率悬浮窗设置"
        Width="400" Height="340"
        MinWidth="400" MinHeight="340"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Icon="app_icon.ico"
        Background="#121214"
        Foreground="#F3F3F5">
    <Window.Resources>
        <!-- Material 3 Textbox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E20"/>
            <Setter Property="Foreground" Value="#F3F3F5"/>
            <Setter Property="BorderBrush" Value="#25FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="8" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#45FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#FF2D55"/>
                                <Setter Property="BorderThickness" TargetName="border" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Material 3 Capsule Button Style -->
        <Style TargetType="Button">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="15" SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Opacity" Value="0.8"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" CenterX="40" CenterY="15"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="服务器连接地址 (URL)" FontSize="12" Foreground="#9090A0" Margin="2,0,0,6"/>
            <TextBox x:Name="TxtServerUrl"/>
        </StackPanel>
        
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="安全 API Token" FontSize="12" Foreground="#9090A0" Margin="2,0,0,6"/>
            <TextBox x:Name="TxtToken"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="显示主题" FontSize="12" Foreground="#9090A0" Margin="2,0,0,6"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RadDarkTheme" Content="深色模式 (暗色/夜间)" Foreground="#F3F3F5" IsChecked="True" Margin="0,0,20,0"/>
                <RadioButton x:Name="RadLightTheme" Content="亮色模式 (明亮/白天)" Foreground="#F3F3F5"/>
            </StackPanel>
        </StackPanel>
        
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="取消" Width="80" Height="30" Click="BtnCancel_Click" Margin="0,0,10,0" Background="#2E2E35" Foreground="#F3F3F5"/>
            <Button Content="保存" Width="80" Height="30" Click="BtnSave_Click" Background="#FF2D55" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
